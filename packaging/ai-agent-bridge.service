[Unit]
Description=AI Agent Bridge daemon
Documentation=https://github.com/markcallen/ai-agent-bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bridge
Group=bridge
StateDirectory=bridge
RuntimeDirectory=bridge
WorkingDirectory=/var/lib/bridge
ExecStart=/usr/bin/ai-agent-bridge --config /etc/ai-agent-bridge/bridge.yaml
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/var/lib/bridge
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
